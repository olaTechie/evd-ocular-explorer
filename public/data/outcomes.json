":2,"k":4,"pct":3.7,"ci_lo":0.1,"ci_hi":10.7,"pi_lo":0,"pi_hi":39.1,"i2":91.9,"tau2":0.01735,"n_total":738,"plain":"Chorioretinitis is inflammation of the retina and the layer beneath it. It was reported in about 3.7% of examined survivors, mostly in more recent, ophthalmologist-led studies (4 in total).","subgroups":[],"studies":[{"study_id":"S50","label":"Berry (2021)","n_cases":22,"n_examined":220,"prevalence":10,"era":"Post-2016","examiner":"Ophthalmologist","species":"EBOV","timing":null,"rob":"Moderate","denominator_note":null},{"study_id":"S45","label":"Mwanza (2025)","n_cases":5,"n_examined":120,"prevalence":4.2,"era":"Post-2016","examiner":"Ophthalmologist","species":"EBOV","timing":"Long-term (>2y)","rob":"Moderate","denominator_note":null},{"study_id":"S15","label":"Steptoe (2020)","n_cases":2,"n_examined":57,"prevalence":3.5,"era":"Post-2016","examiner":"Ophthalmologist","species":"EBOV","timing":"Survivor (>6m)","rob":"Moderate","denominator_note":null},{"study_id":"S26","label":"Hereth (2017)","n_cases":1,"n_examined":341,"prevalence":0.3,"era":"Post-2016","examiner":"Ophthalmologist","species":"EBOV","timing":"Post-acute (1-6m)","rob":"Moderate","denominator_note":null}],"era_figure":"eFigure_forest_chorioretinitis_by_era.png"},{"outcome":"GRD / Ebola retinal lesion","tier":2,"k":4,"pct":12.4,"ci_lo":8.5,"ci_hi":16.8,"pi_lo":4.8,"pi_hi":22.6,"i2":17.8,"tau2":0.00073,"n_total":376,"plain":"This is a distinctive retinal scar that follows the layout of the eye's nerve fibres — sometimes called the Ebola retinal lesion. Around 12.4% of survivors had it in the 4 studies that looked for it specifically. It appears characteristic of Ebola and usually spares central vision.","subgroups":[],"studies":[{"study_id":"S27","label":"Howlett (2018)","n_cases":3,"n_examined":17,"prevalence":17.6,"era":"Post-2016","examiner":"Ophthalmologist","species":"EBOV","timing":"Survivor (>6m)","rob":"High","denominator_note":null},{"study_id":"S15","label":"Steptoe (2020)","n_cases":10,"n_examined":57,"prevalence":17.5,"era":"Post-2016","examiner":"Ophthalmologist","species":"EBOV","timing":"Survivor (>6m)","rob":"Moderate","denominator_note":null},{"study_id":"S36","label":"Steptoe (2017)","n_cases":12,"n_examined":82,"prevalence":14.6,"era":"2014-2016","examiner":"Mixed team","species":"EBOV","timing":"Survivor (>6m)","rob":"Moderate","denominator_note":"true 12/82=14.6% type-6 lesion (was 16/82)"},{"study_id":"S50","label":"Berry (2021)","n_cases":22,"n_examined":220,"prevalence":10,"era":"Post-2016","examiner":"Ophthalmologist","species":"EBOV","timing":null,"rob":"Moderate","denominator_note":null}],"era_figure":"eFigure_forest_grd_ebola_retinal_lesion_by_era.png"},{"outcome":"Glaucoma","tier":2,"k":3,"pct":8.8,"ci_lo":0,"ci_hi":32.9,"pi_lo":0,"pi_hi":100,"i2":97.7,"tau2":0.06984,"n_total":976,"plain":"Glaucoma involves raised pressure inside the eye that can damage the optic nerve. About 8.8% of survivors were affected, but from only 3 studies with very different results, so this estimate is highly uncertain.","subgroups":[],"studies":[{"study_id":"S06","label":"Balendra (2023)","n_cases":34,"n_examined":128,"prevalence":26.6,"era":"Post-2016","examiner":"Ophthalmologist","species":"EBOV","timing":"Survivor (>6m)","rob":"Moderate","denominator_note":null},{"study_id":"S04","label":"Shantha (2022)","n_cases":3,"n_examined":46,"prevalence":6.5,"era":"Post-2016","examiner":"Ophthalmologist","species":null,"timing":"Long-term (>2y)","rob":"Moderate","denominator_note":null},{"study_id":"S10","label":"Etard (2017)","n_cases":9,"n_examined":802,"prevalence":1.1,"era":"2014-2016","examiner":"Non-specialist","species":"EBOV","timing":"Survivor (>6m)","rob":"Low-Moderate","denominator_note":null}],"era_figure":"eFigure_forest_glaucoma_by_era.png"},{"outcome":"Vitreous opacities","tier":2,"k":4,"pct":4.7,"ci_lo":1.8,"ci_hi":8.8,"pi_lo":0,"pi_hi":23.5,"i2":92.2,"tau2":0.00628,"n_total":2133,"plain":"These are floaters and haze in the eye's clear gel, often left behind by inflammation. About 4.7% of examined survivors were affected (4 studies).","subgroups":[],"studies":[{"study_id":"S40","label":"Vandy (2016)","n_cases":22,"n_examined":277,"prevalence":7.9,"era":"2014-2016","examiner":"Ophthalmologist","species":"EBOV","timing":"Survivor (>6m)","rob":"Moderate","denominator_note":null},{"study_id":"S42","label":"Eghrari (2015)","n_cases":44,"n_examined":564,"prevalence":7.8,"era":"2014-2016","examiner":"Ophthalmologist","species":"EBOV","timing":"Survivor (>6m)","rob":"Low","denominator_note":null},{"study_id":"S50","label":"Berry (2021)","n_cases":7,"n_examined":250,"prevalence":2.8,"era":"Post-2016","examiner":"Ophthalmologist","species":"EBOV","timing":"Long-term (>2y)","rob":"Low","denominator_note":null},{"study_id":"S08","label":"Choo (2024)","n_cases":21,"n_examined":1042,"prevalence":2,"era":"Post-2016","examiner":"Ophthalmologist","species":"EBOV","timing":"Long-term (>2y)","rob":"Moderate","denominator_note":null}],"era_figure":"eFigure_forest_vitreous_opacities_by_era.png"}]